# ==============================================================================
# gpu-insights-otel - Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env': cp .env.example .env
# 2. Populate the variables below with your specific instance details.
# 3. NEVER commit the actual '.env' file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Splunk HTTP Event Collector (HEC) Configuration
# ------------------------------------------------------------------------------
# URL for your Splunk HEC endpoint. 
# For Splunk Cloud, it usually looks like: https://http-inputs-<host>.splunkcloud.com/services/collector
SPLUNK_HEC_URL=https://<your-splunk-instance>:8088/services/collector

# The HEC Token generated in your Splunk Data Inputs settings.
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# ------------------------------------------------------------------------------
# 2. Cluster Metadata (Passed to OpenTelemetry)
# ------------------------------------------------------------------------------
# These tags enrich the telemetry to calculate economics per region/hardware.
CLUSTER_REGION=us-west-accelerated-1
HARDWARE_ARCHITECTURE=hopper-h100
DEPLOY_ENVIRONMENT=production

# ------------------------------------------------------------------------------
# 3. Application Tuning
# ------------------------------------------------------------------------------
# Scrape interval for the NVIDIA DCGM Exporter (in seconds)
DCGM_SCRAPE_INTERVAL=10
